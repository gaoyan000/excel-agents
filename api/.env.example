# Copy to .env and fill in. The app runs fully offline (heuristic fallback)
# WITHOUT a key — the key only upgrades mapping/NL-SQL quality.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Where raw uploads + metadata DB live (defaults are fine for local dev).
STORAGE_DIR=./storage
METADATA_DB=./storage/metadata.db
# Comma-separated CORS origins for the Next.js frontend.
CORS_ORIGINS=http://localhost:3000

# Raw-file storage backend: "local" (default) or "r2" (Cloudflare R2).
# r2 requires `pip install boto3`. DuckDB reads CSV straight from R2 via
# httpfs; xlsx is cached locally on first read.
STORAGE_BACKEND=local
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
